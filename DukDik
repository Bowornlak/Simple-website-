<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">

    <title>DukDik</title>
</head>
                   <!--Head-->
<header style="margin-top: 50px; margin-inline: 100px;">
    <div class="circle"></div>
</header>
                   <!--Arms-->
<body>
    <span style="color: #555;">
        <div class="square" style="margin-inline:105px; height: 150px; width: 40px;"></div>
        <div class="square" style="margin-top: -150px; height: 150px; width: 40px; margin-inline: 300px;"></div>
    </span>
                   <!--Body-->
    <div class="square" style="margin-top: -150px; margin-bottom: 5px;"></div>
                   <!--Skirt-->    
    <div class="trapezoid" style="height: 0px; width: 80px; margin-top: 0px;"></div>
                <!--Legs-->
<footer>
    <div class="rectangle" style="padding-inline: 5 px; margin-inline: 160px; margin-top: 5px;">
    <div class="rectangle" style="padding-inline: 5 px; margin-inline: 80px;">
    </div>
</div>

</footer>
</body>
</html>
